generator client {
  provider = "prisma-client-js"
}

// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

enum UserRoleEnum {
  ADMIN
  USER
}

enum ProductStatusEnum {
  ACTIVE
  CANCELLED
}

enum ProductReceiptTypeEnum {
  SHIPMENT
  CORRECTION
  RETURN
  OTHER
}

enum ProductIssueEnum {
  SALE
  CORRECTION
  OTHER
}

enum ProductReserveStatusEnum {
  ACTIVE
  FULFILLED
  CANCELLED
}

enum YandexSyncStatusEnum {
  SUCCESS
  ERROR
}

enum OzonSyncStatusEnum {
  SUCCESS
  ERROR
}

enum CurrencyEnum {
  RUB
  USD
  RMB
}

enum PriceTypeEnum {
  DEALER
  RETAIL
  YANDEX
  OZON
}

enum PriceUnitEnum {
  M2
  ITEM
}

model ChipSize {
  id           String    @id @default(uuid())
  name         String    @unique
  displayOrder Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products Product[]
}

model Settings {
  id        String   @id @default(uuid())
  field     String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImageGroupArray {
  id             String   @id @default(uuid())
  imageGroupName String   @unique
  fileNamesArr   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id               String       @id @default(uuid())
  name             String
  role             UserRoleEnum @default(USER)
  email            String       @unique
  password         String
  resetToken       String?      @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Product {
  id               String            @id @default(uuid())
  sku              String            @unique
  displayOrder     Int?
  descriptionShort String?
  descriptionLong  String?
  imageGroupName   String
  fileNamesArr     String            @default("[]")
  status           ProductStatusEnum
  length_mm        Int
  width_mm         Int
  thickness_mm     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productGroupId String
  productGroup   ProductGroup? @relation(fields: [productGroupId], references: [id])

  chipSizeId String?
  chipSize   ChipSize? @relation(fields: [chipSizeId], references: [id])

  productVariants      ProductVariant[]
  yandexMarketMappings YandexMarketMapping[]
  ozonMappings         OzonMapping[]
  prices               Price[]
}

model ProductVariant {
  id                String @id @default(uuid())
  variantName       String // e.g., "Batch A - Light", "Batch B - Dark"
  warehouseQuantity Int    @default(0) // Physical stock: receipts - issues
  availableQuantity Int    @default(0) // Available for sale: warehouseQuantity - active reserves

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productReceipts ProductReceipt[]
  productIssues   ProductIssue[]
  productReserves ProductReserve[]

  @@index([productId])
}

model ProductGroup {
  id           String @id @default(uuid())
  name         String
  displayOrder Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ProductReceipt {
  id          String                 @id @default(uuid())
  quantity    Int
  receiptDate DateTime
  description String?
  type        ProductReceiptTypeEnum

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId String

  @@index([productVariantId])
}

model ProductIssue {
  id          String           @id @default(uuid())
  quantity    Int
  issueDate   DateTime
  description String?
  type        ProductIssueEnum

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId String

  @@index([productVariantId])
}

model YandexMarketMapping {
  id           String @id @default(uuid())
  yandexSku    String @unique
  buffer       Int?
  divisor      Int?
  priceMarkup  Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model OzonMapping {
  id          String   @id @default(uuid())
  ozonOfferId String   @unique
  buffer      Int?
  divisor     Int?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model OzonSyncLog {
  id        String             @id @default(uuid())
  status    OzonSyncStatusEnum
  trigger   String
  message   String?
  skuCount  Int?

  createdAt DateTime @default(now())
}

model YandexSyncLog {
  id        String               @id @default(uuid())
  status    YandexSyncStatusEnum
  trigger   String
  message   String?
  skuCount  Int?

  createdAt DateTime @default(now())
}

model ProductReserve {
  id          String                   @id @default(uuid())
  quantity    Int
  reserveDate DateTime
  client      String
  status      ProductReserveStatusEnum

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId String

  @@index([productVariantId])
}

model Price {
  id           String        @id @default(uuid())
  type         PriceTypeEnum
  priceInCents Int
  currency     CurrencyEnum
  unit         PriceUnitEnum @default(M2)
  quantity     Int           @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, type])
  @@index([productId])
}
